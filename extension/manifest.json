{
  "manifest_version": 3,
  "name": "Markdown Clipper",
  "short_name": "MarkdownClip",
  "version": "1.1.0",
  "description": "Capture web pages - including SharePoint - as clean Markdown. Copy, edit, save locally, or capture reusable collections.",
  "homepage_url": "https://github.com/rjs-solutions/markdown-clipper",
  "icons": {
    "16": "assets/icons/icon-16.png",
    "32": "assets/icons/icon-32.png",
    "48": "assets/icons/icon-48.png",
    "128": "assets/icons/icon-128.png"
  },
  "action": {
    "default_title": "Clip page to Markdown",
    "default_popup": "src/popup/index.html",
    "default_icon": {
      "16": "assets/icons/icon-16.png",
      "32": "assets/icons/icon-32.png",
      "48": "assets/icons/icon-48.png",
      "128": "assets/icons/icon-128.png"
    }
  },
  "options_page": "src/options/index.html",
  "side_panel": {
    "default_path": "src/popup/index.html?panel=1"
  },
  "background": {
    "service_worker": "src/background/service-worker.js",
    "type": "module"
  },
  "permissions": [
    "activeTab",
    "scripting",
    "downloads",
    "storage",
    "sidePanel",
    "alarms",
    "contextMenus"
  ],
  "host_permissions": [
    "https://cdn.syndication.twimg.com/*"
  ],
  "optional_host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "src/content/*.js",
        "src/lib/markdown.js",
        "src/lib/settings.js",
        "src/lib/settings-schema.js",
        "src/lib/slug.js",
        "src/lib/template.js",
        "src/lib/tweet.js",
        "src/vendor/*.js",
        "src/popup/index.html"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ],
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Alt+M"
      }
    }
  }
}
